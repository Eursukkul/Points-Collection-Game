# Local defaults match docker-compose.yml — no .env needed for local dev.
# In production these are injected by the platform (Railway).
DATABASE_URL=postgres://points:points_local@localhost:5432/points_game?sslmode=disable
PORT=8080
FRONTEND_ORIGIN=http://localhost:3000
# true in production (cross-site cookie needs SameSite=None + Secure)
COOKIE_SECURE=false
